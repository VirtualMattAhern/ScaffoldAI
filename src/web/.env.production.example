# Production API URL - used at build time for the frontend
# Copy to .env.production and set your deployed API URL
# Example: https://api.skafoldai.com/api or https://skafoldai-api.azurewebsites.net/api
VITE_API_URL=https://your-api-url.azurewebsites.net/api

# Microsoft Entra ID (optional) - enables "Sign in with Microsoft"
# VITE_ENTRA_CLIENT_ID=your-app-client-id
# VITE_ENTRA_TENANT_ID=your-tenant-id
# VITE_APP_URL=https://www.skafoldai.com
