# Azure OpenAI / Microsoft Foundry - required for AI features
# Get endpoint + key from Foundry: Build → Models → your deployment → Keys/Endpoint
# Endpoint = base URL only (no path). Examples:
#   cognitiveservices.azure.com: https://skafoldai-ai.cognitiveservices.azure.com
#   openai.azure.com: https://skafoldai-ai.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://skafoldai-ai.openai.azure.com
AZURE_OPENAI_API_KEY=your-key-1-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# Optional: Use v1 API format if you get 404 "Resource not found"
# AZURE_OPENAI_USE_V1=true

# Optional: API version (app tries 2024-10-21, 2024-08-01, etc. if not set)
# AZURE_OPENAI_API_VERSION=2024-10-21

# Optional: Server port (default: 3003)
# PORT=3003

# Database - use one of:
# SQLite (local dev): DATABASE_PATH=./data/skafoldai.db
# Azure SQL (production): DATABASE_URL (connection string)
# DATABASE_PATH=/home/data/skafoldai.db
# DATABASE_URL=Server=tcp:skafoldai-sql-wus.database.windows.net,1433;Database=skafoldai-db;User ID=skafoldaiadmin;Password=xxx;Encrypt=true;TrustServerCertificate=false;

# Production: CORS allowed origins (comma-separated)
# CORS_ORIGINS=https://app.skafoldai.com,https://www.skafoldai.com

# Optional: API log level (debug, info, warn, error)
# LOG_LEVEL=info

# Microsoft Entra ID (optional) - for Bearer token validation
# ENTRA_TENANT_ID=your-tenant-id
# ENTRA_CLIENT_ID=your-spa-client-id
